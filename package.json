{
  "name": "pixelframe",
  "version": "1.0.0",
  "description": "PixelFrame - 3D Printing Studio",
  "main": "server/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js",
    "start": "NODE_ENV=production node server/index.js",
    "hash-password": "node -e \"const bcrypt = require('bcryptjs'); const password = process.argv[1]; console.log(bcrypt.hashSync(password, 12));\"",
    "dev:full": "concurrently \"npm run server:dev\" \"npm run dev\""
  },
  "keywords": [
    "3d-printing",
    "pixelframe"
  ],
  "author": "PixelFrame",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "gsap": "^3.14.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "multer": "^2.0.2",
    "three": "^0.182.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
